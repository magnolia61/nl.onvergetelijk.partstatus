<?xml version="1.0"?>
<extension key="nl.onvergetelijk.partstatus" type="module">
  <file>partstatus</file>
  <name>Onvergetelijke Zomerkampen - Partstatus</name>
  <description>Deze extensie verwerkt de participant status obv leeftijd en criteria</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Richard van Oosterhout</author>
    <email>webteam@onvergetelijk.nl</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://www.onvergetelijk.nl</url>
    <url desc="Documentation">https://www.onvergetelijk.nl</url>
    <url desc="Support">https://www.onvergetelijk.nl</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-03-01</releaseDate>
  <version>2.0.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.11</ver>
  </compatibility>
  <comments>This module extension is specific to the Participant Status Lifecycle</comments>
  <civix>
    <namespace>CRM/Partstatus</namespace>
    <format>23.02.1</format>
  </civix>
  <classloader>
    <psr0 prefix="CRM_Partstatus_" path="."/>
    <psr4 prefix="Civi\Partstatus\" path="Civi"/>
  </classloader>
  <mixins>
    <mixin>menu-xml@1.0.0</mixin>
    <mixin>mgd-php@1.0.0</mixin>
  </mixins>
</extension>