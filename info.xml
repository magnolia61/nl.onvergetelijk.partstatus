<?xml version="1.0"?>
<extension key="nl.onvergetelijk.leeftijd" type="module">
  <file>leeftijd</file>
  <name>Onvergetelijke Zomerkampen - Leeftijd</name>
  <description>Deze extensie berekent de leeftijd op 1 augustus van de komende zomer</description>
  <license>GNU AGPL</license>
  <maintainer>
    <author>Richard van Oosterhout</author>
    <email>webteam@onvergetelijk.nl</email>
  </maintainer>
  <releaseDate>2021-02-01</releaseDate>
  <version>1.1</version>
  <develStage>beta</develStage>
  <compatibility>
    <ver>5.34</ver>
  </compatibility>
  <comments>This module extension is specific to the Promotie Custom Field Group</comments>
  <civix>
    <namespace>CRM/Leeftijd</namespace>
    <format>23.02.1</format>
  </civix>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <mixins>
    <mixin>menu-xml@1.0.0</mixin>
    <mixin>mgd-php@1.0.0</mixin>
  </mixins>
</extension>
